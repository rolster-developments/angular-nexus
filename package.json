{
  "name": "@rolster/angular-store",
  "version": "19.1.1",
  "type": "module",
  "description": "Library that allows you to manage the status of Angular applications.",
  "license": "MIT",
  "author": "Rolster Technology <rolster.developments@gmail.com>",
  "contributors": [
    {
      "name": "Daniel Andrés Castillo Pedroza",
      "email": "ing.dacastillop@gmail.com"
    }
  ],
  "types": "./dist/esm/index.d.ts",
  "main": "./dist/cjs/index.cjs",
  "module": "./dist/esm/index.js",
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.ts",
      "node": {
        "require": "./dist/cjs/index.cjs",
        "import": "./dist/esm/index.js"
      },
      "default": "./dist/esm/index.js"
    }
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "prettier": "prettier --write \"src/**/*.{ts}\"",
    "clean": "rimraf ./dist",
    "build": "npm run clean && tsc -p tsconfig.app.json && rollup -c rollup.config.mjs",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@angular/core": "^17.3.12 || ^18.2.14 || ^19.2.19",
    "@rolster/commons": "^4.1.0"
  },
  "devDependencies": {
    "@rolster/rollup": "^2.0.0",
    "@rolster/types": "^1.1.0",
    "@vitest/ui": "^3.2.4",
    "jsdom": "^27.0.0",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "tslib": "^2.4.0",
    "typescript": "^5.7.2",
    "vitest": "^3.2.4"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rolster-developments/typescript-store.git"
  },
  "keywords": [
    "rolster",
    "typescript",
    "angular",
    "store",
    "reactive",
    "manager-state"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=14.13"
  }
}

